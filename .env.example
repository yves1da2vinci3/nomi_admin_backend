DATABASE_URL="postgresql://user:pass@localhost:5432/nomi"
ADMIN_API_TOKEN="change-me-long-random"
# Optional: UUID of an Admin row — when using Bearer ADMIN_API_TOKEN, sets req.adminAuth.sub (needed for /studio/projects etc.)
# ADMIN_API_ACTING_SUB=""
# ADMIN_API_ACTING_EMAIL="api-token@local.invalid"
JWT_SECRET="minimum-sixteen-chars-change-in-production"
JWT_EXPIRES_IN="8h"
PORT=4001
ADMIN_CORS_ORIGIN="http://localhost:8080"

# Optional — without it, /studio/ai/* returns 503 (other routes still work)
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Seed (scripts/seed-admin.ts)
SEED_ADMIN_EMAIL="admin@nomi.local"
SEED_ADMIN_PASSWORD="changeme"
