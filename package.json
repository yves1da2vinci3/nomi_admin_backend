{
  "name": "nomi-admin-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "prisma generate && tsc --noEmit",
    "typecheck": "tsc --noEmit",
