    "express": "^4.21.2",
    "jose": "^6.2.3",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.9",
    "eslint": "^10.3.0",
    "prisma": "^6.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2"
  }
